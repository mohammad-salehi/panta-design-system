{
  "name": "@msalehi79/panta-design-system",
  "version": "1.0.1",
  "description": "Design system with Tailwind and dark/light theme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:tsup && npm run build:css",
    "build:tsup": "tsup",
    "build:css": "postcss src/styles/global.css --output dist/styles.css",
    "copy-fonts": "shx cp -r src/assets/fonts dist/",
    "prepublishOnly": "npm run build && npm run copy-fonts",
    "dev": "concurrently \"tsup --watch\" \"postcss src/styles/global.css --output dist/styles.css --watch\""
  },
  "keywords": [
    "design-system",
    "nextjs",
    "tailwind",
    "dark-mode"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "recharts": "^3.8.1"
  }
}
